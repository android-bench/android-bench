diff --git a/build.gradle.kts b/build.gradle.kts
--- a/build.gradle.kts	(revision 0fda5605f58924a46a840426b738afb15de79bc4)
+++ b/build.gradle.kts	(revision f996a8f622bec440b6778d50352d1d6114ebe472)
@@ -43,4 +43,84 @@
             )
         }
     }
+
+    tasks.withType<Test>().configureEach {
+        if (name.matches(Regex("(?i)testDebugUnitTest"))) {
+            dependsOn(rootProject.tasks.named("computeBuildConfigOffenders"))
+            val isBomAppliedPath = rootProject.layout.buildDirectory
+                .file("isComposeBomApplied.txt")
+                .map { it.asFile.absolutePath }
+            val composeDependenciesNotUsingBom = rootProject.layout.buildDirectory
+                .file("composeDependencies.txt")
+                .map { it.asFile.absolutePath }
+            systemProperty("buildConfigGuard.composeBomApplied", isBomAppliedPath.get())
+            systemProperty(
+                "buildConfigGuard.composeDependencies",
+                composeDependenciesNotUsingBom.get()
+            )
+            
+            doFirst {
+                println(
+                    "[guard] $path isBomAppliedFile = " +
+                            systemProperties["buildConfigGuard.composeBomApplied"]
+                )
+                println(
+                    "[guard] $path composeDependenciesNotUsingBomFile = " +
+                            systemProperties["buildConfigGuard.composeDependencies"]
+                )
+            }
+        }
+    }
+}
+
+val isComposeBomApplied = layout.buildDirectory.file("isComposeBomApplied.txt")
+val composeDependenciesNotUsingBom = layout.buildDirectory.file("composeDependencies.txt")
+val computeBuildConfigOffenders by tasks.registering {
+    notCompatibleWithConfigurationCache("Test task")
+    doLast {
+        val targetGroup = "androidx.compose"
+        val targetName = "compose-bom"
+        val outBomDeclaration = isComposeBomApplied.get().asFile
+        val outDependencies = composeDependenciesNotUsingBom.get().asFile
+        outBomDeclaration.parentFile.mkdirs()
+        outDependencies.parentFile.mkdirs()
+        rootProject.allprojects.firstOrNull { it.name == "app" }?.let { p ->
+            p.configurations.filter { it.name in listOf("implementation", "api") }
+                .any { config ->
+                    config.dependencies.any { dep ->
+                        val matchesName = dep.group == targetGroup && dep.name == targetName
+
+                        val isPlatform = if (dep is ModuleDependency) {
+                            val category = dep.attributes.getAttribute(Category.CATEGORY_ATTRIBUTE)
+                            category?.name == Category.REGULAR_PLATFORM || category?.name == Category.ENFORCED_PLATFORM
+                        } else {
+                            false
+                        }
+
+                        matchesName && isPlatform
+                    }
+                }.apply {
+                    outBomDeclaration.writeText("${p.name}->$this")
+                }
+            p.configurations.filter {
+                it.name in listOf(
+                    "implementation",
+                    "api",
+                    "debugImplementation",
+                    "androidTestImplementation"
+                )
+            }.flatMap {
+                it.dependencies.filterIsInstance<ExternalModuleDependency>()
+                    .filter { dep ->
+                        dep.group?.startsWith(targetGroup) == true && dep.group != "androidx.compose.material3" && dep.name != targetName && dep.version != null
+                    }.map { dep ->
+                        it to dep
+                    }
+            }.apply {
+                outDependencies.writeText(joinToString("\n") {
+                    "$p -> ${it.first.name} -> ${it.second.group}:${it.second.name}:${it.second.version}"
+                })
+            }
+        }
+    }
 }
