new file mode 100644
--- /dev/null	(revision f996a8f622bec440b6778d50352d1d6114ebe472)
+++ b/app/src/test/java/com/jerboa/ComposeBomTest.kt	(revision f996a8f622bec440b6778d50352d1d6114ebe472)
@@ -0,0 +1,38 @@
+package com.jerboa
+
+import org.junit.Test
+import java.io.File
+
+class ComposeBomTest {
+
+    @Test
+    fun composeBomIsApplied() {
+        val path = System.getProperty("buildConfigGuard.composeBomApplied")
+        val dependenciesPath = System.getProperty("buildConfigGuard.composeDependencies")
+        val modules = path.readFile()
+            .map {
+                val list = it.split("->")
+                list[0] to list[1].toBooleanStrict()
+            }
+
+        val dependencies = dependenciesPath.readFile()
+
+        assert(modules.isNotEmpty() && modules.all { it.second }) {
+            """ComposeBom is not applied at the following modules in api or implementation configuration:
+${modules.joinToString("\n") { it.first }}
+            """
+        }
+        assert(dependencies.isEmpty()) {
+            """The following dependencies are not using Compose BOM:
+${dependencies.joinToString("\n")}
+            """
+        }
+    }
+
+    private fun String?.readFile(): List<String> = this?.let(::File)
+        ?.takeIf { it.exists() }
+        ?.readLines()
+        ?.map { it.trim() }
+        ?.filter { it.isNotEmpty() }
+        .orEmpty()
+}
