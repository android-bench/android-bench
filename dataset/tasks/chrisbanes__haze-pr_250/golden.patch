-  private fun Effect.updateParameters(
-    bounds: Rect,
-    blurRadiusPx: Float,
-    noiseFactor: Float,
-    tint: Color,
-    shape: Shape,
-  ): Boolean {
-    if (!renderEffectDirty) {
-      renderEffectDirty = this.blurRadiusPx != blurRadiusPx ||
-        this.tint != tint ||
-        this.noiseFactor != noiseFactor
