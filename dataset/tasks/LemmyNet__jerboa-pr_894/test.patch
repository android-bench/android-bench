new file mode 100644
--- /dev/null	(date 1764343639279)
+++ b/app/src/androidTest/java/com/jerboa/ImageViewerDialogTest.kt	(date 1764343639279)
@@ -0,0 +1,111 @@
+package com.jerboa
+
+import android.graphics.Bitmap
+import android.graphics.BitmapFactory
+import androidx.compose.ui.test.ExperimentalTestApi
+import androidx.compose.ui.test.doubleClick
+import androidx.compose.ui.test.isRoot
+import androidx.compose.ui.test.junit4.createComposeRule
+import androidx.compose.ui.test.performTouchInput
+import androidx.test.platform.app.InstrumentationRegistry
+import androidx.test.uiautomator.UiDevice
+import com.jerboa.ui.components.common.ImageViewerDialog
+import org.junit.After
+import org.junit.Rule
+import org.junit.Test
+import java.io.File
+
+class ImageViewerDialogTest {
+    @get:Rule
+    val composeTestRule = createComposeRule()
+
+    @After
+    fun cleanup() {
+        val context = InstrumentationRegistry.getInstrumentation().targetContext
+        val cacheDir = context.cacheDir
+        val screenshots = listOf("before.png", "after.png")
+
+        screenshots.forEach { fileName ->
+            val file = File(cacheDir, fileName)
+            if (file.exists()) {
+                val deleted = file.delete()
+                if (!deleted) {
+                    println("Warning: Failed to delete $fileName from cache")
+                } else {
+                    println("Deleted $fileName from cache")
+                }
+            }
+        }
+    }
+
+    @OptIn(ExperimentalTestApi::class)
+    @Test
+    fun doubleTap_doesNotTriggerBack_andZoomsImage() {
+        var backRequested = false
+        val testDrawableRes = com.jerboa.test.R.drawable.test
+
+        composeTestRule.setContent {
+            ImageViewerDialog(
+                url = "android.resource://com.jerboa.debug.test/$testDrawableRes",
+                onBackRequest = { backRequested = true }
+            )
+        }
+
+        composeTestRule.waitForIdle()
+
+        val allRootNodes = composeTestRule.onAllNodes(isRoot())
+        val (dialogNodeIndex, _) = allRootNodes.fetchSemanticsNodes()
+            .mapIndexed { index, node -> index to (node.layoutInfo.width * node.layoutInfo.height) }
+            .maxByOrNull { it.second }
+            ?: error("No dialog node found")
+        val dialogNode = allRootNodes[dialogNodeIndex]
+
+        val uiDevice = UiDevice.getInstance(InstrumentationRegistry.getInstrumentation())
+
+        // Capture screenshot BEFORE zoom
+        val before = captureDeviceScreenshot(uiDevice, "before.png")
+
+        // Perform double-tap at center
+        dialogNode.performTouchInput {
+            doubleClick(center)
+        }
+
+        // Wait for animation or ripple effect to finish
+        composeTestRule.waitForIdle()
+
+        // Capture screenshot AFTER zoom
+        val after = captureDeviceScreenshot(uiDevice, "after.png")
+
+        // Compare pixel difference (different = zoomed)
+        val beforeHash = before.pixelHash() // force evaluation
+        val afterHash = after.pixelHash()
+        assert(beforeHash != afterHash) { "Double-tap should zoom the image." }
+
+        // Ensure double-tap didn't trigger back
+        assert(!backRequested) { "Double-tap must NOT trigger back press" }
+    }
+
+    private fun captureDeviceScreenshot(device: UiDevice, fileName: String): Bitmap {
+        val tmpFile =
+            File(InstrumentationRegistry.getInstrumentation().targetContext.cacheDir, fileName)
+        if (tmpFile.exists()) tmpFile.delete()
+
+        val success = device.takeScreenshot(tmpFile)
+        check(success) { "Failed to take screenshot" }
+
+        val bitmap = BitmapFactory.decodeFile(tmpFile.absolutePath)
+        check(bitmap != null) { "Failed to decode screenshot bitmap" }
+        return bitmap
+    }
+
+    private fun Bitmap.pixelHash(sampleStep: Int = 10): Int {
+        var hash = 0
+        for (x in 0 until width step sampleStep) {
+            for (y in 0 until height step sampleStep) {
+                val pixel = getPixel(x, y)
+                hash = 31 * hash + pixel
+            }
+        }
+        return hash
+    }
+}
