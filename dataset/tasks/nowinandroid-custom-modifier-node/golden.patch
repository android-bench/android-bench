+private fun Modifier.touchDirectionCapture(analyticsHelper: AnalyticsHelper): Modifier =
+    this.then(TouchDirectionModifierNodeElement(analyticsHelper))
+
+private class TouchDirectionModifierNodeElement(val analyticsHelper: AnalyticsHelper) :
+    ModifierNodeElement<TouchDirectionModifierNode>() {
+    override fun create(): TouchDirectionModifierNode = TouchDirectionModifierNode(analyticsHelper)
+
+    override fun hashCode(): Int {
+        return analyticsHelper.hashCode()
+    }
+
+    override fun equals(other: Any?): Boolean {
+        val otherTyped = other as? TouchDirectionModifierNodeElement ?: return false
+        return analyticsHelper == otherTyped.analyticsHelper
+    }
+
+    override fun update(node: TouchDirectionModifierNode) {
+        node.analyticsHelper = analyticsHelper
+    }
+}
+
+private class TouchDirectionModifierNode(var analyticsHelper: AnalyticsHelper) : Modifier.Node(),
+    PointerInputModifierNode {
+    private var downEvent: PointerInputChange? = null
+
+    override fun onCancelPointerInput() {
+        downEvent = null
+    }
+
+    override fun onPointerEvent(
+        pointerEvent: PointerEvent,
+        pass: PointerEventPass,
+        bounds: IntSize,
+    ) {
+        // only track during the main pass
+        if (pass != PointerEventPass.Main) return
+        val change = pointerEvent.changes.first()
+        val currentDown = downEvent
+        if (currentDown == null) {
+            if (change.changedToDownIgnoreConsumed()) {
+                downEvent = change
+            }
+        } else if (change.changedToUpIgnoreConsumed()) {
+            val delta = change.position - currentDown.position
+            val swipeDirection = when {
+                delta.y < 0f -> "UP"
+                delta.y > 0f -> "DOWN"
+                else -> ""
+            }
+            analyticsHelper.logEvent(
+                AnalyticsEvent(
+                    IMPRESSION,
+                    listOf(
+                        AnalyticsEvent.Param(
+                            AnalyticsEvent.ParamKeys.SWIPE_DIRECTION, swipeDirection,
+                        ),
+                    ),
+                ),
+            )
+            downEvent = null
+        }
+    }
+}
