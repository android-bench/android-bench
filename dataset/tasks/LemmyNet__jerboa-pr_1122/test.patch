+package com.jerboa
+
+import androidx.compose.ui.test.*
+import androidx.compose.ui.test.junit4.createAndroidComposeRule
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.jerboa.FakeAPI.Companion.sampleCommentScore
+import com.jerboa.FakeAPI.Companion.sampleInboxScore
+import com.jerboa.FakeAPI.Companion.samplePostViewCounts
+import com.jerboa.FakeAPI.Companion.testPost
+import com.jerboa.api.API
+import com.jerboa.api.DEFAULT_INSTANCE
+import com.jerboa.db.AppDB
+import com.jerboa.db.entity.Account
+import kotlinx.coroutines.runBlocking
+import org.junit.After
+import org.junit.Before
+import org.junit.Rule
+import org.junit.Test
+import org.junit.runner.RunWith
+
+
+@RunWith(AndroidJUnit4::class)
+class ScoreVisibilityTest {
+
+    private val testUser = "Tester"
+
+    @get:Rule
+    val composeTestRule = createAndroidComposeRule<MainActivity>()
+
+    private val fakeApi = FakeAPI()
+
+    @Before
+    fun setup() {
+        API.mockApi = fakeApi
+
+        val context = composeTestRule.activity.applicationContext
+        val db = AppDB.getDatabase(context)
+
+        runBlocking {
+            db.accountDao().insert(
+                Account(
+                    id = 1, current = true, instance = DEFAULT_INSTANCE, name = testUser,
+                    jwt = "jwt", defaultListingType = 0, defaultSortType = 0,
+                    verificationState = 8 // CHECKS_COMPLETE, we "trick" the app into believing the account has already passed all security checks
+                    // AccountVerificationState.CHECKS_COMPLETE
+                )
+            )
+        }
+    }
+
+    @After
+    fun tearDown() {
+        API.mockApi = null
+    }
+
+    @Test
+    fun testTogglingShowScoresHidesScoresOnHomeCommentsInbox() {
+
+        val doneText = composeTestRule.activity.getString(R.string.dialogs_done)
+        composeTestRule.onAllNodesWithText(doneText, ignoreCase = true).apply {
+            if (fetchSemanticsNodes().isNotEmpty()) onFirst().performClick()
+        }
+
+        val inboxLabel = composeTestRule.activity.getString(R.string.bottomBar_label_inbox)
+        composeTestRule.onNodeWithText(inboxLabel).performClick()
+        composeTestRule.waitForIdle()
+        composeTestRule.onAllNodesWithText(sampleInboxScore.toString())
+            .onFirst()
+            .assertIsDisplayed()
+
+        val homeLabel = composeTestRule.activity.getString(R.string.bottomBar_label_home)
+        composeTestRule.onNodeWithText(homeLabel).performClick()
+        composeTestRule.waitForIdle()
+        composeTestRule.onAllNodesWithText(samplePostViewCounts.toString())
+            .onFirst()
+            .assertIsDisplayed()
+
+        composeTestRule.onAllNodesWithText(testPost, substring = true).onFirst()
+            .performClick()
+        composeTestRule.waitForIdle()
+        composeTestRule.onAllNodesWithText(sampleCommentScore.toString())
+            .onFirst()
+            .assertIsDisplayed()
+
+        composeTestRule.onNodeWithTag("jerboa:back").performClick()
+
+        composeTestRule.onRoot().performTouchInput { swipeRight() }
+        val settingsText = composeTestRule.activity.getString(R.string.home_settings)
+        composeTestRule.onNodeWithText(settingsText).performClick()
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText(
+            "$testUser ${composeTestRule.activity.getString(R.string.settings_activity_settings)}",
+            ignoreCase = true
+        ).performClick()
+
+        val toggle = composeTestRule.onNodeWithText(
+            composeTestRule.activity.getString(R.string.account_settings_show_scores),
+            ignoreCase = true
+        )
+        toggle.performScrollTo()
+        toggle.performClick()
+        composeTestRule.waitForIdle()
+
+        // Important: save before going back.
+        val saveSettings = composeTestRule.onNodeWithText(
+            composeTestRule.activity.getString(R.string.account_settings_save_settings),
+            ignoreCase = true
+        )
+        saveSettings.performScrollTo().performClick()
+
+        composeTestRule.onNodeWithTag("jerboa:back").performClick()
+        composeTestRule.onNodeWithTag("jerboa:back").performClick()
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText(inboxLabel).performClick()
+        composeTestRule.waitForIdle()
+        composeTestRule.onAllNodesWithText(sampleInboxScore.toString()).assertCountEquals(0)
+
+        composeTestRule.onNodeWithText(homeLabel).performClick()
+        composeTestRule.waitForIdle()
+        composeTestRule.onAllNodesWithText(samplePostViewCounts.toString()).assertCountEquals(0)
+
+        composeTestRule.onAllNodesWithText(testPost, substring = true).onFirst()
+            .performClick()
+        composeTestRule.waitForIdle()
+        composeTestRule.onAllNodesWithText(sampleCommentScore.toString()).assertCountEquals(0)
+    }
+}
