+package com.jerboa
+
+import androidx.lifecycle.LiveData
+import androidx.lifecycle.MutableLiveData
+import com.jerboa.db.APP_SETTINGS_DEFAULT
+import com.jerboa.db.AppSettings
+import com.jerboa.db.AppSettingsDao
+
+class FakeAppSettingsDao : AppSettingsDao {
+
+    private val state = MutableLiveData(APP_SETTINGS_DEFAULT)
+
+    override fun getSettings(): LiveData<AppSettings> = state
+
+    override suspend fun updateAppSettings(appSettings: AppSettings) {
+        state.postValue(appSettings)
+    }
+
+    override suspend fun markChangelogViewed() {
+        val current = state.value ?: APP_SETTINGS_DEFAULT
+        state.postValue(current.copy(viewedChangelog = 1))
+    }
+
+    override suspend fun updatePostViewMode(postViewMode: Int) {
+        val current = state.value ?: APP_SETTINGS_DEFAULT
+        state.postValue(current.copy(postViewMode = postViewMode))
+    }
+}
