+    @Test
+    fun `should provide account list excluding selected account for dropdown`() = runTest {
+        val displayAccounts = createDisplayAccountList(3)
+        val getDisplayAccountsFlow = MutableStateFlow(displayAccounts)
+        val testSubject = createTestSubject(
+            displayAccountsFlow = getDisplayAccountsFlow,
+        )
+
+        advanceUntilIdle()
+
+        val selectedAccount = testSubject.state.value.selectedAccount
+        val availableAccounts = testSubject.state.value.accounts
+
+        assertThat(availableAccounts.contains(selectedAccount)).isEqualTo(true)
+        assertThat(availableAccounts.size).isEqualTo(displayAccounts.size)
+    }
+
+    @Test
+    fun `should update selected account when OnAccountClick is received with different account`() = runTest {
+        val displayAccounts = createDisplayAccountList(3)
+        val getDisplayAccountsFlow = MutableStateFlow(displayAccounts)
+        val testSubject = createTestSubject(
+            displayAccountsFlow = getDisplayAccountsFlow,
+        )
+
+        advanceUntilIdle()
+
+        val initialSelectedAccount = testSubject.state.value.selectedAccount
+        val newAccount = displayAccounts.find { it != initialSelectedAccount }!!
+
+        testSubject.event(Event.OnAccountClick(newAccount))
+
+        advanceUntilIdle()
+
+        assertThat(testSubject.state.value.selectedAccount).isEqualTo(newAccount)
+        assertThat(testSubject.state.value.selectedAccount).isNotEqualTo(initialSelectedAccount)
+    }
+
+    @Test
+    fun `should handle account selection state correctly with multiple accounts`() = runTest {
+        val displayAccounts = createDisplayAccountList(4)
+        val getDisplayAccountsFlow = MutableStateFlow(displayAccounts)
+        val testSubject = createTestSubject(
+            displayAccountsFlow = getDisplayAccountsFlow,
+        )
+
+        advanceUntilIdle()
+
+        assertThat(testSubject.state.value.accounts.size).isEqualTo(4)
+        assertThat(testSubject.state.value.selectedAccount).isEqualTo(displayAccounts.first())
+
+        testSubject.event(Event.OnAccountClick(displayAccounts[2]))
+
+        advanceUntilIdle()
+
+        assertThat(testSubject.state.value.selectedAccount).isEqualTo(displayAccounts[2])
+        assertThat(testSubject.state.value.accounts.size).isEqualTo(4)
+    }
+
     private fun createTestSubject(
         drawerConfigFlow: Flow<DrawerConfig> = flow { emit(createDrawerConfig()) },
         displayAccountsFlow: Flow<List<DisplayAccount>> = flow { emit(emptyList()) },
