+package com.jerboa
+
+import androidx.lifecycle.LiveData
+import androidx.lifecycle.MutableLiveData
+import com.jerboa.db.Account
+import com.jerboa.db.AccountDao
+
+class FakeAccountDao : AccountDao {
+    // In-memory storage
+    private val accountsState = MutableLiveData(
+        listOf(
+            Account(
+                id = 0,
+                current = true,
+                instance = "Test",
+                name = "TestName",
+                jwt = "fakeToken",
+                defaultListingType = 0,
+                defaultSortType = 0
+            )
+        )
+    )
+    private var currentAccountId: Int? = null
+
+    override fun getAll(): LiveData<List<Account>> = accountsState
+
+    override fun getAllSync(): List<Account> = accountsState.value ?: emptyList()
+
+    override suspend fun insert(account: Account) {
+        val current = accountsState.value ?: emptyList()
+        accountsState.postValue(current + account)
+    }
+
+    override suspend fun update(account: Account) {
+        val current = accountsState.value ?: emptyList()
+        accountsState.postValue(current.map { if (it.id == account.id) account else it })
+    }
+
+    override suspend fun removeCurrent() {
+        currentAccountId = null
+    }
+
+    override suspend fun setCurrent(accountId: Int) {
+        if ((accountsState.value ?: emptyList()).any { it.id == accountId }) {
+            currentAccountId = accountId
+        }
+    }
+
+    override suspend fun delete(account: Account) {
+        val current = accountsState.value ?: emptyList()
+        accountsState.postValue(current.filter { it.id != account.id })
+        if (currentAccountId == account.id) currentAccountId = null
+    }
+}
