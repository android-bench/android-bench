+package com.jerboa
+
+import androidx.compose.ui.geometry.Offset
+import androidx.compose.ui.test.assertIsDisplayed
+import androidx.compose.ui.test.hasText
+import androidx.compose.ui.test.junit4.createEmptyComposeRule
+import androidx.compose.ui.test.onNodeWithContentDescription
+import androidx.compose.ui.test.onNodeWithText
+import androidx.compose.ui.test.onRoot
+import androidx.compose.ui.test.performClick
+import androidx.compose.ui.test.performTouchInput
+import androidx.compose.ui.test.swipe
+import androidx.test.core.app.ActivityScenario
+import androidx.test.core.app.ApplicationProvider
+import androidx.test.platform.app.InstrumentationRegistry
+import com.jerboa.db.AccountRepository
+import com.jerboa.db.AppSettingsRepository
+import kotlinx.coroutines.test.runTest
+import org.junit.Before
+import org.junit.Rule
+import org.junit.Test
+
+class MainActivityTests {
+
+    lateinit var scenario: ActivityScenario<MainActivity>
+
+    @get:Rule
+    val composeTestRule = createEmptyComposeRule()
+
+    @Before
+    fun setup() {
+        val app = ApplicationProvider.getApplicationContext<JerboaApplication>()
+        val fakeAccountRepository = AccountRepository(FakeAccountDao())
+        val fakeAppSettingsRepository = AppSettingsRepository(FakeAppSettingsDao())
+
+        val accountRepositoryDelegateField = JerboaApplication::class.java
+            .getDeclaredField("accountRepository\$delegate")
+        accountRepositoryDelegateField.isAccessible = true
+        accountRepositoryDelegateField.set(app, lazy { fakeAccountRepository })
+
+        val appSettingsRepositoryDelegateField = JerboaApplication::class.java
+            .getDeclaredField("appSettingsRepository\$delegate")
+        appSettingsRepositoryDelegateField.isAccessible = true
+        appSettingsRepositoryDelegateField.set(app, lazy { fakeAppSettingsRepository })
+
+        scenario = ActivityScenario.launch(MainActivity::class.java)
+    }
+
+    @Test
+    fun testDrawerOpensOnEveryTab() = runTest {
+        scenario.onActivity { }
+
+        val tabs = listOf("Home", "Search", "Inbox", "Saved", "Profile")
+        tabs.forEach { tab ->
+            // Switch to the tab
+            val labelRes = when (tab) {
+                "Home" -> R.string.bottomBar_label_home
+                "Search" -> R.string.bottomBar_label_search
+                "Inbox" -> R.string.bottomBar_label_inbox
+                "Saved" -> R.string.bottomBar_label_bookmarks
+                "Profile" -> R.string.bottomBar_label_profile
+                else -> throw IllegalStateException("Unknown tab: $tab")
+            }
+            val context = InstrumentationRegistry.getInstrumentation().targetContext
+
+            // Close popup if displayed
+            if (composeTestRule.onAllNodes(hasText("Done")).fetchSemanticsNodes().isNotEmpty()) {
+                composeTestRule.onNodeWithText("Done").performClick()
+            }
+
+            composeTestRule.onNodeWithText(context.getString(labelRes)).performClick()
+
+            // Swipe to open drawer
+            composeTestRule.onRoot().performTouchInput {
+                swipe(
+                    start = Offset(60f, 40f),
+                    end = Offset(this.centerX, 40f),
+                    durationMillis = 300
+                )
+            }
+
+            composeTestRule.awaitIdle()
+
+            // Verify drawer content is displayed
+            composeTestRule.onNodeWithText("Anonymous").assertIsDisplayed()
+
+            // Close the drawer
+            scenario.onActivity { activity ->
+                activity.onBackPressedDispatcher.onBackPressed()
+            }
+
+            composeTestRule.awaitIdle()
+        }
+    }
+
+    @Test
+    fun testDrawerOpensOnHamburgerClick() = runTest {
+        scenario.onActivity { }
+
+        /* Only testing these three since on Saved/Profile sections a different view is displayed
+           in testing env due to user being logged out/network issue. */
+        val tabs = listOf("Home", "Search", "Inbox")
+        tabs.forEach { tab ->
+            // Switch to the tab
+            val labelRes = when (tab) {
+                "Home" -> R.string.bottomBar_label_home
+                "Search" -> R.string.bottomBar_label_search
+                "Inbox" -> R.string.bottomBar_label_inbox
+                else -> throw IllegalStateException("Unknown tab: $tab")
+            }
+            val context = InstrumentationRegistry.getInstrumentation().targetContext
+
+            // Close popup if displayed
+            if (composeTestRule.onAllNodes(hasText("Done")).fetchSemanticsNodes().isNotEmpty()) {
+                composeTestRule.onNodeWithText("Done").performClick()
+            }
+
+            composeTestRule.onNodeWithText(context.getString(labelRes)).performClick()
+            composeTestRule.awaitIdle()
+
+
+            // Click the hamburger icon
+            composeTestRule.onNodeWithContentDescription(context.getString(R.string.home_menu)).performClick()
+
+            composeTestRule.awaitIdle()
+
+            // Verify drawer content is displayed
+            composeTestRule.onNodeWithText("Anonymous").assertIsDisplayed()
+
+            // Close the drawer
+            scenario.onActivity { activity ->
+                activity.onBackPressedDispatcher.onBackPressed()
+            }
+
+            composeTestRule.awaitIdle()
+        }
+    }
+}
