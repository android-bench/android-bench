+package io.element.android.features.roomlist.impl
+
+import androidx.compose.ui.test.ExperimentalTestApi
+import androidx.compose.ui.test.SemanticsNodeInteraction
+import androidx.compose.ui.test.SemanticsNodeInteractionCollection
+import androidx.compose.ui.test.assertIsDisplayed
+import androidx.compose.ui.test.junit4.createComposeRule
+import androidx.compose.ui.test.onAllNodesWithText
+import androidx.compose.ui.test.onNodeWithText
+import androidx.compose.ui.test.onRoot
+import androidx.compose.ui.test.performTouchInput
+import androidx.compose.ui.test.swipeUp
+import androidx.test.platform.app.InstrumentationRegistry
+import io.element.android.features.roomlist.impl.components.DefaultRoomListTopBarPreview
+import org.junit.Rule
+import org.junit.Test
+
+class RoomListTopBarTests {
+
+    @get:Rule
+    val composeTestRule = createComposeRule()
+
+    @OptIn(ExperimentalTestApi::class)
+    @Test
+    fun checkTitleTextSize() {
+        val context = InstrumentationRegistry.getInstrumentation().targetContext
+
+        composeTestRule.setContent {
+            DefaultRoomListTopBarPreview()
+        }
+
+        composeTestRule.mainClock.autoAdvance = false
+
+        val titleHeightBefore = composeTestRule.onNodeWithText(context.getString(R.string.screen_roomlist_main_space_title))
+            .assertIsDisplayed()
+            .fetchSemanticsNode()
+            .boundsInRoot.height
+
+        composeTestRule.onRoot().performTouchInput {
+            swipeUp(endY = height * 0.7f)
+        }
+
+        val titleHeightBetween = composeTestRule.onAllNodesWithText(context.getString(R.string.screen_roomlist_main_space_title), useUnmergedTree = true)
+            .onTopMost()
+            .assertIsDisplayed()
+            .fetchSemanticsNode()
+            .boundsInRoot.height
+
+        composeTestRule.mainClock.autoAdvance = true
+
+        val titleHeightAfter = composeTestRule.onNodeWithText(context.getString(R.string.screen_roomlist_main_space_title))
+            .assertIsDisplayed()
+            .fetchSemanticsNode()
+            .boundsInRoot.height
+
+        assert(titleHeightBefore > titleHeightAfter) { "Title height should be smaller after scroll happens" }
+        assert(titleHeightBetween == titleHeightAfter) { "Title height in the top position should be the same throughout the scroll animation" }
+    }
+
+    private fun SemanticsNodeInteractionCollection.onTopMost(): SemanticsNodeInteraction {
+        val nodes = this
+            .fetchSemanticsNodes()
+
+        val topMostIndex = nodes
+            .withIndex()
+            .minBy { it.value.boundsInRoot.top }
+            .index
+
+        return this[topMostIndex]
+    }
+}
