+package com.google.maps.android.compose
+
+import androidx.compose.runtime.getValue
+import androidx.compose.runtime.mutableStateOf
+import androidx.compose.runtime.setValue
+import androidx.compose.ui.test.junit4.createComposeRule
+import androidx.compose.ui.test.onRoot
+import androidx.compose.ui.test.performClick
+import com.google.android.gms.maps.model.LatLng
+import junit.framework.TestCase.assertFalse
+import junit.framework.TestCase.assertTrue
+import org.junit.Rule
+import org.junit.Test
+
+class GoogleMapTests {
+
+    @get:Rule
+    val composeTestRule = createComposeRule()
+
+    @Test
+    fun testMapClickCallbackGetsUpdated() {
+        var oldCalled = false
+        var newCalled = false
+
+        var callback: (LatLng) -> Unit by mutableStateOf({ oldCalled = true })
+
+        composeTestRule.setContent {
+            GoogleMap(
+                onMapClick = callback,
+                onMapLongClick = null,
+                onMapLoaded = null,
+                onPOIClick = null,
+                onMyLocationClick = null,
+                onMyLocationButtonClick = null,
+            )
+        }
+
+        callback = { newCalled = true }
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onRoot().performClick()
+
+        composeTestRule.waitUntil { oldCalled || newCalled }
+
+        assertFalse("Old callback should not be called", oldCalled)
+        assertTrue("New callback should be called", newCalled)
+    }
+}
