+    fun checkScrollableComponents() {
+        val scrollableViews = composeTestRule.onRoot()
+            .findScrollableDescendantsAtSameDepth()
+
+        assert(scrollableViews.size == 1) { "Should not have multiple scrollable views in the same depth." }
+    }
+
+    fun checkFirstSideEventPositionAfterScrollingUp() {
+        val firstSideEvent =
+            composeTestRule.onAllNodesWithText(SideEvents.first().title.currentLangTitle)
+                .onFirst()
+
+        val firstSideEventPositionBeforeScroll = firstSideEvent
+            .fetchSemanticsNode()
+            .boundsInRoot
+            .top
+
+        composeTestRule.onRoot()
+            .performTouchInput {
+                swipe(
+                    Offset(x = (width / 2).toFloat(), y = (height / 3) * 2f),
+                    Offset(x = (width / 2).toFloat(), y = height / 3f)
+                )
+            }
+
+        composeTestRule.waitForIdle()
+
+        val firstSideEventPositionAfterScroll = firstSideEvent
+            .fetchSemanticsNode()
+            .boundsInRoot
+            .top
+
+        assert(firstSideEventPositionBeforeScroll - firstSideEventPositionAfterScroll > 1f) {
+            "First SideEvent should move up after scrolling up"
+        }
+    }
+
+    fun SemanticsNodeInteraction.findScrollableDescendantsAtSameDepth(): List<SemanticsNode> {
+        val root = fetchSemanticsNode()
+
+        var currentLevel: List<SemanticsNode> = root.children
+
+        while (currentLevel.isNotEmpty()) {
+            val foundAtThisLevel = currentLevel.filter { node ->
+                val config = node.config
+                config.contains(SemanticsActions.ScrollBy) ||
+                    config.contains(SemanticsActions.ScrollToIndex)
+            }
+
+            if (foundAtThisLevel.isNotEmpty()) {
+                return foundAtThisLevel
+            }
+
+            currentLevel = currentLevel.flatMap { it.children }
+        }
+
+        return emptyList()
+    }
 }
