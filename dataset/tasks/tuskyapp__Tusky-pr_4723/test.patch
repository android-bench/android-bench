+    @Test
+    fun markupHiddenUrls_emojiAndEmoteTest() {
+        val url = "https://corteximplant.com"
+
+        // Test cases: (input text, span start, span end) for custom emotes
+        val cases = listOf(
+            Triple(":cyberdon: link text", 0, 10),
+            Triple("link text :blob_happy:", 10, 22),
+            Triple(" :blob_joy: link text", 1, 11),
+            Triple("link :cat_eyes: text", 5, 15),
+            Triple("link text :fox_cool: ", 10, 20)
+        )
+
+        for ((input, start, end) in cases) {
+            // Create a Spannable with a URLSpan covering the entire input text
+            val content = SpannableStringBuilder().append(input, URLSpan(url), 0)
+
+            // Attach an EmojiSpan to the specified range
+            val emojiSpan = EmojiSpan(textView).also {
+                content.setSpan(it, start, end, Spannable.SPAN_EXCLUSIVE_EXCLUSIVE)
+            }
+
+            val result = markupHiddenUrls(textView, content)
+
+            // Verify the final string matches the expected format: "original text (🔗 domain)"
+            val expected = "$input (🔗 corteximplant.com)"
+            Assert.assertEquals("Failed on input: $input", expected, result.toString())
+
+            // Verify that the original EmojiSpan is still present and attached to the correct range.
+            val spans = result.getSpans(start, end, EmojiSpan::class.java)
+            Assert.assertTrue("EmojiSpan should be preserved for input: $input", spans.contains(emojiSpan))
+        }
+    }
