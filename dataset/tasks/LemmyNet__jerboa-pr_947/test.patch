diff --git a/app/src/androidTest/java/com/jerboa/SideMenTest.kt b/app/src/androidTest/java/com/jerboa/SideMenTest.kt
new file mode 100644
--- /dev/null	(revision c3cf62423925b694d10bd6510524a850e026a38a)
+++ b/app/src/androidTest/java/com/jerboa/SideMenTest.kt	(revision c3cf62423925b694d10bd6510524a850e026a38a)
@@ -0,0 +1,61 @@
+package com.jerboa
+
+import androidx.compose.ui.test.junit4.createComposeRule
+import androidx.compose.ui.test.onNodeWithText
+import androidx.lifecycle.MutableLiveData
+import androidx.navigation.compose.rememberNavController
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import androidx.test.platform.app.InstrumentationRegistry
+import com.jerboa.db.AccountViewModel
+import com.jerboa.ui.components.home.DrawerContent
+import io.mockk.every
+import io.mockk.mockk
+import org.junit.Before
+import org.junit.Rule
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class SideMenTest {
+    val accountViewModel = mockk<AccountViewModel>()
+    
+    @get:Rule
+    val composeTestRule = createComposeRule()
+
+    @Before
+    fun setup() {
+        every { accountViewModel.allAccounts } returns MutableLiveData(emptyList())
+    }
+
+    @Test
+    fun testSideMenuContentVisibleWhenAccountExpanded() {
+        val context = InstrumentationRegistry.getInstrumentation().targetContext
+        composeTestRule.setContent {
+            DrawerContent(
+                showAccountAddMode = true,
+                navController = rememberNavController(),
+                accountViewModel = accountViewModel,
+                onSwitchAccountClick = {},
+                onSignOutClick = {},
+                onClickListingType = {},
+                onCommunityClick = {},
+                onClickProfile = {},
+                onClickInbox = {},
+                onClickSaved = {},
+                onClickSettings = {},
+                onClickCommunities = {},
+                myUserInfo = null,
+                unreadCount = 0,
+                blurNSFW = false
+            )
+        }
+
+        composeTestRule
+            .onNodeWithText(context.getString(R.string.home_add_account))
+            .assertExists()
+
+        composeTestRule
+            .onNodeWithText(context.getString(R.string.home_local))
+            .assertExists()
+    }
+}
