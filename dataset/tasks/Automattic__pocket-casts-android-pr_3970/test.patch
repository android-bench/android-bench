+package au.com.shiftyjelly.pocketcasts.ui
+
+import android.content.Context
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import androidx.test.platform.app.InstrumentationRegistry
+import au.com.shiftyjelly.pocketcasts.PocketCastsApplication
+import au.com.shiftyjelly.pocketcasts.servers.di.InterceptorModule.PocketCastsPublicUserAgent
+import au.com.shiftyjelly.pocketcasts.ui.di.UiModule
+import coil.ImageLoader
+import coil.request.ImageRequest
+import okhttp3.OkHttpClient
+import okhttp3.mockwebserver.MockResponse
+import okhttp3.mockwebserver.MockWebServer
+import org.junit.After
+import org.junit.Assert.assertEquals
+import org.junit.Before
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class CoilImageLoaderTest {
+    lateinit var context: Context
+    lateinit var imageLoader: ImageLoader
+
+    lateinit var mockWebServer: MockWebServer
+
+    @Before
+    fun setUp() {
+        context = InstrumentationRegistry.getInstrumentation().targetContext.applicationContext
+
+        mockWebServer = MockWebServer()
+        mockWebServer.start()
+
+        imageLoader = (context as? PocketCastsApplication)?.coilImageLoader!!
+    }
+
+    @Test
+    fun testPocketCastsUserAgentIsPresentInImageLoadRequest() {
+        val artworkAddress = mockWebServer.url("/podcast.png")
+
+        mockWebServer.enqueue(MockResponse().setResponseCode(404))
+        imageLoader.enqueue(ImageRequest.Builder(context).data(artworkAddress).build())
+
+        val request = mockWebServer.takeRequest()
+        assertEquals("User agent header should be pocketcasts", PocketCastsPublicUserAgent, request.getHeader("User-Agent"))
+    }
+
+    @After
+    fun tearDown() {
+        mockWebServer.shutdown()
+    }
+}
