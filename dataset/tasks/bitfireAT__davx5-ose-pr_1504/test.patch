+package at.bitfire.davdroid.ui
+
+import android.view.KeyEvent
+import androidx.activity.ComponentActivity
+import androidx.compose.material3.SnackbarHostState
+import androidx.compose.runtime.remember
+import androidx.compose.ui.test.ExperimentalTestApi
+import androidx.compose.ui.test.assertIsFocused
+import androidx.compose.ui.test.hasText
+import androidx.compose.ui.test.junit4.createAndroidComposeRule
+import androidx.compose.ui.test.onNodeWithText
+import androidx.test.espresso.IdlingRegistry
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import androidx.test.platform.app.InstrumentationRegistry
+import androidx.test.uiautomator.UiDevice
+import at.bitfire.davdroid.ui.setup.AdvancedLoginScreen
+import at.bitfire.davdroid.ui.setup.EmailLoginScreen
+import at.bitfire.davdroid.ui.setup.UrlLoginScreen
+import org.junit.Rule
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class LoginScreenTests {
+
+    @get:Rule
+    val composeTestRule = createAndroidComposeRule<ComponentActivity>()
+
+    @Test
+    fun testFocusSwitchingOnEmailLoginScreen() {
+        IdlingRegistry.getInstance().resources.forEach {
+            if (it.name == "Compose-Espresso link") {
+                IdlingRegistry.getInstance().unregister(it)
+            }
+        }
+        composeTestRule.setContent {
+            EmailLoginScreen(
+                email = "test@email.com",
+                onSetEmail = { },
+                password = "test_password",
+                onSetPassword = { },
+                canContinue = false,
+            )
+        }
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("test@email.com")
+            .assertIsFocused()
+
+        val device = UiDevice.getInstance(InstrumentationRegistry.getInstrumentation())
+        device.pressKeyCode(KeyEvent.KEYCODE_TAB)
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("test_password")
+            .assertIsFocused()
+    }
+
+    @Test
+    fun testFocusSwitchingOnAdvancedLoginScreen() {
+        IdlingRegistry.getInstance().resources.forEach {
+            if (it.name == "Compose-Espresso link") {
+                IdlingRegistry.getInstance().unregister(it)
+            }
+        }
+        composeTestRule.setContent {
+            AdvancedLoginScreen(
+                snackbarHostState = remember { SnackbarHostState() },
+                url = "https://test.com",
+                onSetUrl = {},
+                username = "TestUser",
+                onSetUsername = {},
+                password = "test_password",
+                onSetPassword = {},
+                certAlias = "test_cert",
+                onSetCertAlias = {},
+                canContinue = false,
+            )
+        }
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("https://test.com")
+            .assertIsFocused()
+
+        val device = UiDevice.getInstance(InstrumentationRegistry.getInstrumentation())
+        device.pressKeyCode(KeyEvent.KEYCODE_TAB)
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("TestUser")
+            .assertIsFocused()
+
+        device.pressKeyCode(KeyEvent.KEYCODE_TAB)
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("test_password")
+            .assertIsFocused()
+    }
+
+    @Test
+    fun testFocusSwitchingOnUrlLoginScreen() {
+        IdlingRegistry.getInstance().resources.forEach {
+            if (it.name == "Compose-Espresso link") {
+                IdlingRegistry.getInstance().unregister(it)
+            }
+        }
+        composeTestRule.setContent {
+            UrlLoginScreen(
+                url = "https://test.com",
+                onSetUrl = {},
+                username = "TestUser",
+                onSetUsername = {},
+                password = "test_password",
+                onSetPassword = {},
+                canContinue = false,
+            )
+        }
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("https://test.com")
+            .assertIsFocused()
+
+        val device = UiDevice.getInstance(InstrumentationRegistry.getInstrumentation())
+        device.pressKeyCode(KeyEvent.KEYCODE_TAB)
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("TestUser")
+            .assertIsFocused()
+
+        device.pressKeyCode(KeyEvent.KEYCODE_TAB)
+
+        composeTestRule.waitForIdle()
+
+        composeTestRule.onNodeWithText("test_password")
+            .assertIsFocused()
+    }
+}
