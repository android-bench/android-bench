+package com.jerboa
+
+import com.jerboa.ui.components.home.HomeHeader
+import androidx.compose.material3.ExperimentalMaterial3Api
+import androidx.compose.material3.MaterialTheme
+import androidx.compose.material3.TopAppBarDefaults
+import androidx.compose.material3.rememberTopAppBarState
+import androidx.compose.runtime.rememberCoroutineScope
+import androidx.compose.ui.test.assertIsDisplayed
+import androidx.compose.ui.test.hasClickAction
+import androidx.compose.ui.test.junit4.StateRestorationTester
+import androidx.compose.ui.test.junit4.createComposeRule
+import androidx.compose.ui.test.onLast
+import androidx.compose.ui.test.onNodeWithTag
+import androidx.compose.ui.test.onNodeWithText
+import androidx.compose.ui.test.performClick
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import androidx.test.platform.app.InstrumentationRegistry
+import com.jerboa.datatypes.sampleInstantScores
+import com.jerboa.datatypes.samplePostView
+import com.jerboa.db.entity.AnonAccount
+import com.jerboa.feat.PostActionBarMode
+import com.jerboa.feat.default
+import com.jerboa.ui.components.community.CommunityHeader
+import com.jerboa.ui.components.post.PostFooterLine
+import it.vercruysse.lemmyapi.datatypes.LocalUserVoteDisplayMode
+import it.vercruysse.lemmyapi.dto.ListingType
+import it.vercruysse.lemmyapi.dto.SortType
+import org.junit.Rule
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class ConfigurationChangesTest {
+
+    @get:Rule
+    val composeTestRule = createComposeRule()
+
+    @OptIn(ExperimentalMaterial3Api::class)
+    @Test
+    fun homeHeaderOnConfigChange() {
+        val restorationTester = StateRestorationTester(composeTestRule)
+        val context = InstrumentationRegistry.getInstrumentation().targetContext
+
+        val refreshText = context.getString(R.string.home_refresh)
+
+        restorationTester.setContent {
+            MaterialTheme {
+                HomeHeader(
+                    openDrawer = {},
+                    onClickSortType = {},
+                    onClickListingType = {},
+                    onClickRefresh = {},
+                    onClickPostViewMode = {},
+                    selectedSortType = SortType.Active,
+                    selectedListingType = ListingType.All,
+                    selectedPostViewMode = PostViewMode.Card,
+                    onClickSiteInfo = {},
+                    scrollBehavior = TopAppBarDefaults.enterAlwaysScrollBehavior(rememberTopAppBarState())
+                )
+            }
+        }
+
+        composeTestRule.onNodeWithTag("jerboa:options").performClick()
+
+        composeTestRule.onNodeWithText(refreshText).assertIsDisplayed()
+
+        restorationTester.emulateSavedInstanceStateRestore()
+
+        composeTestRule.onNodeWithText(refreshText).assertIsDisplayed()
+    }
+
+    @OptIn(ExperimentalMaterial3Api::class)
+    @Test
+    fun communityHeaderOnConfigChange() {
+        val restorationTester = StateRestorationTester(composeTestRule)
+        val context = InstrumentationRegistry.getInstrumentation().targetContext
+        val communityInfoText = context.getString(R.string.community_community_info)
+
+        restorationTester.setContent {
+            MaterialTheme {
+                CommunityHeader(
+                    communityName = "Test Community",
+                    onClickSortType = {},
+                    onBlockCommunityClick = {},
+                    onClickRefresh = {},
+                    onClickPostViewMode = {},
+                    selectedSortType = SortType.Active,
+                    selectedPostViewMode = PostViewMode.Card,
+                    onClickCommunityInfo = {},
+                    onClickCommunityShare = {},
+                    onClickBack = {},
+                    scrollBehavior = TopAppBarDefaults.enterAlwaysScrollBehavior(rememberTopAppBarState()),
+                    isBlocked = false
+                )
+            }
+        }
+
+        composeTestRule.onAllNodes(hasClickAction()).onLast().performClick()
+
+        composeTestRule.onNodeWithText(communityInfoText).assertIsDisplayed()
+
+        restorationTester.emulateSavedInstanceStateRestore()
+
+        composeTestRule.onNodeWithText(communityInfoText).assertIsDisplayed()
+    }
+
+    @Test
+    fun postFooterLineOnConfigChange() {
+        val restorationTester = StateRestorationTester(composeTestRule)
+        val context = InstrumentationRegistry.getInstrumentation().targetContext
+        val reportPostText = context.getString(R.string.post_listing_report_post)
+
+        restorationTester.setContent {
+            MaterialTheme {
+                val scope = rememberCoroutineScope()
+                PostFooterLine(
+                    postView = samplePostView,
+                    admins = emptyList(),
+                    moderators = emptyList(),
+                    instantScores = sampleInstantScores,
+                    voteDisplayMode = LocalUserVoteDisplayMode.default(),
+                    onUpvoteClick = {},
+                    onDownvoteClick = {},
+                    onReplyClick = {},
+                    onSaveClick = {},
+                    onEditPostClick = {},
+                    onDeletePostClick = {},
+                    onHidePostClick = {},
+                    onReportClick = {},
+                    onRemoveClick = {},
+                    onBanPersonClick = {},
+                    onBanFromCommunityClick = {},
+                    onLockPostClick = {},
+                    onFeaturePostClick = {},
+                    onViewVotesClick = {},
+                    onCommunityClick = {},
+                    onPersonClick = {},
+                    onViewSourceClick = {},
+                    account = AnonAccount,
+                    enableDownVotes = true,
+                    viewSource = false,
+                    postActionBarMode = PostActionBarMode.Long,
+                    fromPostActivity = false,
+                    scope = scope,
+                    showReply = true
+                )
+            }
+        }
+
+        composeTestRule.onAllNodes(hasClickAction()).onLast().performClick()
+
+        composeTestRule.onNodeWithText(reportPostText).assertIsDisplayed()
+
+        restorationTester.emulateSavedInstanceStateRestore()
+
+        composeTestRule.onNodeWithText(reportPostText).assertIsDisplayed()
+    }
+}
