+package com.jerboa
+
+import androidx.compose.ui.geometry.Offset
+import androidx.compose.ui.test.ExperimentalTestApi
+import androidx.compose.ui.test.assertAny
+import androidx.compose.ui.test.click
+import androidx.compose.ui.test.hasClickAction
+import androidx.compose.ui.test.hasText
+import androidx.compose.ui.test.junit4.createAndroidComposeRule
+import androidx.compose.ui.test.onAllNodesWithText
+import androidx.compose.ui.test.onNodeWithText
+import androidx.compose.ui.test.performTouchInput
+import com.jerboa.api.API
+import com.jerboa.datatypes.sampleCommentView
+import com.jerboa.datatypes.sampleReplyCommentView
+import kotlinx.coroutines.test.runTest
+import org.junit.Rule
+import org.junit.Test
+
+class PostActivityTests {
+
+    @get:Rule
+    val composeTestRule = createAndroidComposeRule<TestActivity>()
+
+    @OptIn(ExperimentalTestApi::class)
+    @Test
+    fun testCollapsedCommentsPersistAfterRecreate() = runTest {
+        val companion = API::class.java.getDeclaredField("Companion").get(null)
+        val instanceField = companion.javaClass.getDeclaredField("api")
+        instanceField.isAccessible = true
+        instanceField.set(companion, MockAPI)
+
+        composeTestRule.activityRule.scenario.onActivity { }
+
+        val mainCommentAuthor = sampleCommentView.creator.let { it.display_name ?: it.name }
+        val replyCommentAuthor = sampleReplyCommentView.creator.let { it.display_name ?: it.name }
+
+        // verify both comments are visible
+        composeTestRule.waitUntilAtLeastOneExists(hasText(replyCommentAuthor), 1_000)
+        composeTestRule.onAllNodesWithText(mainCommentAuthor).assertAny(hasClickAction())
+        composeTestRule.onNodeWithText(replyCommentAuthor).assertExists()
+
+        // click on main comment content to collapse the thread
+        composeTestRule.onNodeWithText(replyCommentAuthor).performTouchInput {
+            click(position = Offset(0f, -100f))
+        }
+
+        // verify the thread was collapsed
+        composeTestRule.waitUntilDoesNotExist(hasText(replyCommentAuthor), 1_000)
+
+        // recreate the activity
+        composeTestRule.activityRule.scenario.recreate()
+
+        composeTestRule.awaitIdle()
+
+        // check the thread stayed collapsed
+        composeTestRule.waitUntilDoesNotExist(hasText(replyCommentAuthor), 1_000)
+    }
+}
